# In production these are injected via docker-compose environment: block
# (POSTGRES_DSN and ZITADEL_ISSUER are set there, not in .env)
# Only needed for local dev / alembic CLI runs:
ZITADEL_ISSUER=https://auth.getklai.com
POSTGRES_DSN=postgresql+asyncpg://klai:CHANGEME@localhost:5432/klai

# Defaults — override for Phase 3+ GPU
WHISPER_SERVER_URL=http://whisper-server:8000
STT_PROVIDER=whisper_http
WHISPER_PROVIDER_NAME=whisper-cpu

# Upload limit (MB)
MAX_UPLOAD_MB=100

LOG_LEVEL=INFO
