# Database
DATABASE_URL=postgresql://klai:password@postgres:5432/klai

# Gitea
GITEA_URL=http://gitea:3000
GITEA_ADMIN_TOKEN=your-gitea-admin-token

# Auth (Zitadel OIDC)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_ZITADEL_ISSUER=https://auth.getklai.com
AUTH_ZITADEL_CLIENT_ID=your-client-id
AUTH_ZITADEL_CLIENT_SECRET=your-client-secret

# App
NEXT_PUBLIC_BASE_DOMAIN=getklai.com
CADDY_TENANTS_DIR=/etc/caddy/tenants
