# Klai Infrastructure — Instance Configuration
# Copy this file to config.env, fill in your values, then encrypt:
#   sops --encrypt config.env > config.sops.env
#   rm config.env

# Server
SERVER_HOST=core-01
SERVER_IP=0.0.0.0
SERVER_USER=deploy

# SSH public key to add to the server during setup
SSH_PUBKEY="ssh-ed25519 AAAA... your-email@example.com"

# Domain and contact email
DOMAIN=example.com
ADMIN_EMAIL=info@example.com

# Portal base URL — used for OAuth redirect URIs. Must match the actual URL where the portal is served.
# For getklai.com deployments: https://my.<DOMAIN>
# Defaults to https://portal.<DOMAIN> if unset.
FRONTEND_URL=https://my.<DOMAIN>

# Vexa meeting bot manager
VEXA_BOT_MANAGER_API_KEY=
VEXA_WEBHOOK_SECRET=

# GlitchTip OIDC (Zitadel SSO for admin users — run glitchtip-oidc-setup after adding)
# Create in Zitadel: Project "GlitchTip" → Web app → Code flow → check authorization required
# Callback URL: https://errors.<DOMAIN>/accounts/oidc/zitadel/login/callback/
GLITCHTIP_OIDC_CLIENT_ID=
GLITCHTIP_OIDC_CLIENT_SECRET=

# Taxonomy clustering (SPEC-KB-024)
TAXONOMY_CENTROIDS_DIR=~/.klai/taxonomy_centroids
TAXONOMY_CENTROID_MATCH_THRESHOLD=0.85
TAXONOMY_AUTO_CATEGORISE_THRESHOLD=0.82
TAXONOMY_CLUSTER_MIN_SIZE=5
TAXONOMY_CLUSTER_TRIGGER_COUNT=20

# Klai Connector (GitHub App + credential encryption)
CONNECTOR_ZITADEL_CLIENT_ID=
CONNECTOR_ZITADEL_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
# Generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
CONNECTOR_ENCRYPTION_KEY=

# Google Drive OAuth connector (SPEC-KB-025)
# Create at console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Application type: Web application
# Authorized redirect URI: https://my.<DOMAIN>/api/oauth/google_drive/callback
# Required scope: https://www.googleapis.com/auth/drive.readonly
# Leave empty to disable the Google Drive connector tile.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
