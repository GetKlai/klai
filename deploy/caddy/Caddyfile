# Caddy with Hetzner DNS plugin for wildcard TLS
# Build first: see caddy/build.sh

{
    email {$ADMIN_EMAIL}
    admin off
}

# All subdomains under one wildcard cert
*.{$DOMAIN} {
    tls {
        dns hetzner {$HETZNER_AUTH_API_TOKEN}
        propagation_delay 120s
    }

    log {
        # JSON to stdout for Alloy → VictoriaLogs pipeline (queryable in Grafana)
        output stdout
        format json
    }
    log access-file {
        # File backup for direct server access
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }

    # Generate X-Request-ID for trace correlation across Caddy → backend services.
    # request_header sets it on the upstream REQUEST (not response), so backends see it.
    @no-request-id {
        not header X-Request-ID *
    }
    request_header @no-request-id X-Request-ID "{http.request.uuid}"

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "0"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=self, camera=()"
        -Server
    }

    # X-Frame-Options for all routes except auth (Zitadel must be frameable for OIDC in iframe)
    @not-auth {
        not host auth.{$DOMAIN}
    }
    header @not-auth Content-Security-Policy "frame-ancestors 'self' https://*.{$DOMAIN}"

    # Block /metrics from external access — scraped internally by Alloy
    handle /metrics {
        respond 404
    }

    # Logs ingest (VictoriaLogs push endpoint for remote Alloy agents)
    @logs-ingest host logs-ingest.{$DOMAIN}
    handle @logs-ingest {
        @no_token {
            not header Authorization "Bearer {$VICTORIALOGS_INGEST_TOKEN}"
        }
        respond @no_token 401
        # VictoriaLogs requires basic auth — pass credentials upstream
        reverse_proxy victorialogs:9428 {
            header_up Authorization "Basic {$VICTORIALOGS_BASIC_AUTH_B64}"
        }
    }

    # Auth (Zitadel)
    @auth host auth.{$DOMAIN}
    handle @auth {
        # Allow framing from our own domains for OIDC flow inside portal iframe.
        header Content-Security-Policy "frame-ancestors 'self' *.{$DOMAIN}"
        # Zitadel handles its own rate limiting internally
        reverse_proxy h2c://zitadel:8080
    }

    # LiteLLM model proxy — /health only (for uptime monitoring)
    @llm host llm.{$DOMAIN}
    handle @llm {
        handle /health/liveliness {
            reverse_proxy litellm:4000
        }
        respond 403
    }

    # Grafana (monitoring dashboards) — basic auth gate before proxying
    # /api/health matcher for Uptime Kuma health check (no auth needed)
    @grafana-health {
        host grafana.{$DOMAIN}
        path /api/health
    }
    handle @grafana-health {
        rate_limit {
            zone grafana_health {
                key {remote_host}
                events 30
                window 1m
            }
        }
        reverse_proxy grafana:3000
    }

    @grafana host grafana.{$DOMAIN}
    handle @grafana {
        rate_limit {
            zone grafana_per_ip {
                key {remote_host}
                events 60
                window 1m
            }
        }
        @grafana-html path / /login /logout /d/* /dashboards* /explore* /alerting* /datasources* /plugins* /admin*
        header @grafana-html Cache-Control "no-cache, no-store, must-revalidate"
        reverse_proxy grafana:3000
    }

    # GlitchTip (frontend error tracking)
    @glitchtip host errors.{$DOMAIN}
    handle @glitchtip {
        rate_limit {
            zone glitchtip_per_ip {
                key {remote_host}
                events 120
                window 1m
            }
        }
        reverse_proxy glitchtip-web:8000
    }

    # Connector API (GitHub + external source sync) — must be before portal /api/* catch-all
    @connector host connector.{$DOMAIN}
    handle @connector {
        rate_limit {
            zone connector_per_ip {
                key {remote_host}
                events 60
                window 1m
            }
        }
        reverse_proxy klai-connector:8200
    }

    # Portal API — stricter limit on sensitive provisioning endpoints
    @portal-api-sensitive {
        path /api/signup /api/billing/*
    }
    handle @portal-api-sensitive {
        rate_limit {
            zone portal_sensitive_per_ip {
                key {remote_host}
                events 10
                window 1m
            }
        }
        reverse_proxy portal-api:8010
    }

    # Knowledge base images served via Garage S3 website endpoint (anonymous reads)
    handle_path /kb-images/* {
        reverse_proxy garage:3902 {
            header_up Host klai-images.web.garage
        }
    }

    # Partner API — external integration surface with per-IP rate limiting
    handle /partner/* {
        rate_limit {
            zone partner_per_ip {
                key {remote_host}
                events 120
                window 1m
            }
        }
        reverse_proxy portal-api:8010
    }

    # Dev environment — dev.getklai.com routes to portal-api-dev + /srv/portal-dev
    # Must come BEFORE the general /api/* handler below.
    # Uses `route` to preserve directive order.
    #
    # SPEC-SEC-008 F-018 — protected by basic_auth to gate public internet access.
    # Credentials stored in SOPS (CADDY_DEV_USERNAME / CADDY_DEV_PASSWORD_HASH).
    @dev-host host dev.{$DOMAIN}
    handle @dev-host {
        basic_auth {
            {$CADDY_DEV_USERNAME} {$CADDY_DEV_PASSWORD_HASH}
        }
        route {
            @dev-api path /api/*
            reverse_proxy @dev-api portal-api-dev:8010

            root * /srv/portal-dev

            @dev-spa-assets path /assets/*
            header @dev-spa-assets Cache-Control "public, max-age=31536000, immutable"

            @dev-spa-html not path /assets/*
            header @dev-spa-html Cache-Control "no-cache"

            try_files {path} /index.html
            file_server
        }
    }

    handle /api/* {
        reverse_proxy portal-api:8010
    }

    # SEC-023 / F-038 — Research/Scribe/Docs are no longer publicly routed.
    # Frontend calls /api/research/*, /api/scribe/*, /api/docs/* which hit the
    # BFF proxy in portal-api (app/api/proxy.py). That handler pulls the Zitadel
    # access_token from the BFF session and forwards to the internal service
    # with Authorization: Bearer injected. The services listen only on the
    # klai-net Docker network now — no Caddy exposure.

    # Vexa meeting bot gateway (SEC-013 F-030 — fix dead route from VEXA-003 migration)
    # Route maps /bots/<path> → api-gateway:8000/<path>. The old `vexa-bot-manager`
    # service was replaced by `api-gateway` during the upstream-main rebuild.
    handle /bots/* {
        rate_limit {
            zone bots_per_ip {
                key {remote_host}
                events 10
                window 1m
            }
        }
        uri strip_prefix /bots
        reverse_proxy api-gateway:8000
    }

    # Portal SPA — static files (fallback for all *.${DOMAIN})
    handle {
        root * /srv/portal

        # Vite hashed assets — immutable long-term cache
        @spa-assets path /assets/*
        header @spa-assets Cache-Control "public, max-age=31536000, immutable"

        # index.html and all SPA routes — always revalidate
        @spa-html not path /assets/*
        header @spa-html Cache-Control "no-cache"

        try_files {path} /index.html
        file_server
    }
}

# Dynamically provisioned tenant LibreChat instances.
# Written to /etc/caddy/tenants/ by portal-api at provisioning time.
# Files survive redeploys via the caddy-tenants Docker volume.
#
# Klai Docs org subdomains are also written here by docs-app on org creation.
# Format: docs-{orgSlug}.caddyfile — routes {org}.${DOMAIN} to docs-app:3010.
# After writing, reload Caddy: docker exec caddy caddy reload --config /etc/caddy/Caddyfile
import /etc/caddy/tenants/*.caddyfile

# Custom domains for Klai Docs (e.g. docs.example.com) — V2
# Requires on_demand_tls in the global block and a caddy build with that module.
