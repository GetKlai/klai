# Zitadel JWT validation
ZITADEL_ISSUER=https://auth.getklai.com

# Shared PostgreSQL (research schema)
POSTGRES_DSN=postgresql+asyncpg://klai:password@postgres:5432/klai

# Vector backend: pgvector (Phase 2) or qdrant (Phase 3+)
VECTOR_BACKEND=pgvector

# Qdrant — only required if VECTOR_BACKEND=qdrant
# QDRANT_URL=http://ai-01-wg:6333
# QDRANT_COLLECTION=research

# Internal service URLs
DOCLING_URL=http://docling-serve:5001
TEI_URL=http://tei:8080
LITELLM_URL=http://litellm:4000
LITELLM_API_KEY=

SEARXNG_URL=http://searxng:8888

# Upload limits
MAX_UPLOAD_MB=50

LOG_LEVEL=INFO
