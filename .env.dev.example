# Klai Local Development Environment
# Copy to .env.dev and fill in the values marked with <...>
# Usage: docker compose -f docker-compose.dev.yml --env-file .env.dev up -d

# ── Docker services passwords (dev defaults, no need to change) ──────────────
POSTGRES_PASSWORD=klai-dev
REDIS_PASSWORD=klai-dev
MONGO_ROOT_PASSWORD=klai-dev
MEILI_MASTER_KEY=klai-dev-meili-key
LITELLM_MASTER_KEY=sk-litellm-dev-key

# ── LLM API key (at least one required for AI features) ─────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>
# MISTRAL_API_KEY=<your-mistral-api-key>

# ── Portal backend (.env in klai-portal/backend/) ───────────────────────────
# These go in klai-portal/backend/.env, NOT in this file.
# Listed here for reference:
#
# DATABASE_URL=postgresql+asyncpg://klai:klai-dev@localhost:5434/klai
# ZITADEL_BASE_URL=https://auth.getklai.com
# ZITADEL_PAT=<get-from-zitadel-console-or-klai-infra-sops>
# PORTAL_SECRETS_KEY=<run: openssl rand -hex 32>
# SSO_COOKIE_KEY=<run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
# CORS_ORIGINS=http://localhost:5174
# DEBUG=true
# MOCK_BILLING=true
# FRONTEND_URL=http://localhost:5174
# REDIS_PASSWORD=klai-dev
# MONGO_ROOT_PASSWORD=klai-dev
# MEILI_MASTER_KEY=klai-dev-meili-key
# LITELLM_MASTER_KEY=sk-litellm-dev-key
# LITELLM_BASE_URL=http://localhost:4000

# ── Portal frontend (.env.local in klai-portal/frontend/) ───────────────────
# These go in klai-portal/frontend/.env.local, NOT in this file.
# Listed here for reference:
#
# VITE_OIDC_AUTHORITY=https://auth.getklai.com
# VITE_OIDC_CLIENT_ID=<get-from-zitadel-console>
# VITE_API_BASE_URL=http://localhost:8010
