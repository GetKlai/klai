# Copy this to .env.local and fill in the values.
# .env.local is gitignored — never commit real values.

# Zitadel OIDC settings
# authority = your Zitadel instance URL (no trailing slash)
VITE_OIDC_AUTHORITY=https://auth.getklai.com

# client_id = Client ID of the "Klai Portal" OIDC app in Zitadel
# Find it in: Zitadel admin → Project "Klai Platform" → Application "Klai Portal"
VITE_OIDC_CLIENT_ID=

# Portal API base URL (FastAPI backend)
VITE_API_BASE_URL=http://localhost:8000
