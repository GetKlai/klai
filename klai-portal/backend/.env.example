# Copy to .env and fill in values. Never commit .env.

# Zitadel — identity provider
ZITADEL_BASE_URL=https://auth.getklai.com
ZITADEL_PAT=          # PORTAL_API_ZITADEL_PAT from klai-infra/.env.sops
ZITADEL_PROJECT_ID=362771533686374406
ZITADEL_PORTAL_APP_ID=362901948573155339    # OIDC app "Klai Portal" in Zitadel console
ZITADEL_PORTAL_ORG_ID=362757920133283846   # Organization where portal users live

DATABASE_URL=postgresql+asyncpg://klai:klai-dev@localhost:5434/klai

CORS_ORIGINS=http://localhost:5174,https://my.getklai.com

# Dev mode — zet op true voor Swagger UI op /docs (nooit in productie!)
# DEBUG=true
# CORS_ALLOW_ORIGIN_REGEX=https://[a-z0-9-]+\.getklai\.com   # already default, override if needed

# Moneybird — see .workflow/specs/billing-moneybird.md
MONEYBIRD_API_TOKEN=          # Personal API token: Moneybird > Instellingen > Externe koppelingen > API
MONEYBIRD_ADMIN_ID=480855402911630899
MONEYBIRD_WEBHOOK_TOKEN=      # Random secret: openssl rand -hex 32
# MOCK_BILLING=false           # Set to true to skip real Moneybird calls (for testing)

# Product IDs — Moneybird > Instellingen > Producten > open product > ID uit URL
# Prijzen excl. BTW: Core €22/mnd, Professional €42/mnd, Complete €60/mnd (yearly = monthly × 12 × 0.8)
# Fetch IDs: source .env && curl -s -H "Authorization: Bearer $MONEYBIRD_API_TOKEN" \
#   "https://moneybird.com/api/v2/$MONEYBIRD_ADMIN_ID/products.json" | python3 -m json.tool
MONEYBIRD_PRODUCT_CORE_MONTHLY=
MONEYBIRD_PRODUCT_CORE_YEARLY=
MONEYBIRD_PRODUCT_PROFESSIONAL_MONTHLY=
MONEYBIRD_PRODUCT_PROFESSIONAL_YEARLY=
MONEYBIRD_PRODUCT_COMPLETE_MONTHLY=
MONEYBIRD_PRODUCT_COMPLETE_YEARLY=

# SSO cookie encryption (Fernet key — stateless encrypted cookie replaces in-memory session cache)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SSO_COOKIE_KEY=
# SSO_COOKIE_MAX_AGE=7776000   # 90 days default; Zitadel session lifetime is the real authority

# LibreChat provisioning — secrets from klai-infra/.env.sops (MONGO_ROOT_PASSWORD, MEILI_MASTER_KEY, LITELLM_MASTER_KEY)
MONGO_ROOT_PASSWORD=
MEILI_MASTER_KEY=
LITELLM_MASTER_KEY=

# Docker infrastructure — paths and container names on the server
# LIBRECHAT_IMAGE=ghcr.io/danny-avila/librechat:v0.8.3-rc2   # update when upgrading LibreChat
# LIBRECHAT_HOST_DATA_PATH=/opt/klai/librechat                # host path for LibreChat volumes
# LIBRECHAT_CONTAINER_DATA_PATH=/librechat                    # container-internal base path
# CADDY_CONTAINER_NAME=klai-core-caddy-1                      # Docker container name for Caddy reload
# CADDY_CONFIG_PATH=/caddy/Caddyfile                          # Caddyfile path inside Caddy container
